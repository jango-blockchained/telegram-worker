{
  "name": "telegram-worker",
  // ACCOUNT_ID: Get from Cloudflare Dashboard > Overview > Account ID
  "account_id": "YOUR_ACCOUNT_ID",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-07",
  "compatibility_flags": ["nodejs_compat"],

  // OBSERVABILITY: Enable logging and sampling
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },

  // VARS: Environment variables (secrets set via `wrangler secret put`)
  "vars": {
    // INTERNAL_KEY: Service-to-service authentication
    "INTERNAL_KEY_BINDING": null,
    // TG_BOT_TOKEN: Telegram Bot API token
    // Set via: wrangler secret put TG_BOT_TOKEN_BINDING
    "TG_BOT_TOKEN_BINDING": null,
    // TG_CHAT_ID: Default Telegram chat ID for notifications
    // Set via: wrangler secret put TG_CHAT_ID_BINDING
    "TG_CHAT_ID_BINDING": null,
    // TELEGRAM_SECRET_TOKEN: Webhook verification token
    // Set via: wrangler secret put TELEGRAM_SECRET_TOKEN
    "TELEGRAM_SECRET_TOKEN": null
  },

  // KV_NAMESPACES: Key-Value storage for config
  "kv_namespaces": [
    {
      "binding": "CONFIG_KV",
      "id": "YOUR_CONFIG_KV_ID"
    }
  ],

  // R2_BUCKETS: Object storage for user uploads
  "r2_buckets": [
    {
      "binding": "UPLOADS_BUCKET",
      // BUCKET_NAME: Your R2 bucket name
      "bucket_name": "YOUR_UPLOADS_BUCKET_NAME"
    }
  ],

  // VECTORIZE: AI embeddings index for RAG
  "vectorize": [
    {
      "binding": "VECTORIZE_INDEX",
      "index_name": "YOUR_INDEX_NAME"
    }
  ],

  // AI: Cloudflare Workers AI
  "ai": {
    "binding": "AI"
  },

  // SERVICES: Service bindings to other workers
  "services": [
    // TRADE_SERVICE: For sending trade notifications
    { "binding": "TRADE_SERVICE", "service": "trade-worker" },
    // WEBHOOK_RECEIVER_API: For receiving Telegram updates
    { "binding": "WEBHOOK_RECEIVER_API", "service": "hoox" }
  ]
}