# Telegram Worker Environment Variables (local development)
# Copy to .dev.vars and replace with actual values from `hoox setup` output.
# .dev.vars is gitignored — never commit secrets.

# Internal auth key for service-to-service authentication
INTERNAL_KEY_BINDING=your_internal_key_binding_here

# Telegram Bot Token (get from @BotFather on Telegram)
TG_BOT_TOKEN_BINDING=your_telegram_bot_token_here

# Comma-separated list of authorized chat IDs
AUTHORIZED_CHAT_IDS=12345678,87654321
